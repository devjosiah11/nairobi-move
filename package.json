{
  "name": "nairobi-move",
  "private": true,
  "workspaces": [
    "shared/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w sacco-dashboard\" \"npm run dev -w boda-dispatch\" \"npm run dev -w registration\" \"npm run dev -w matatu-pulse\"",
    "dev:sacco": "npm run dev -w sacco-dashboard",
    "dev:boda": "npm run dev -w boda-dispatch",
    "dev:reg": "npm run dev -w registration",
    "dev:matatu": "npm run dev -w matatu-pulse",
    "dev:landing": "npm run dev -w landing"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "vite": "^7.3.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-plugin": "^1.167.28",
    "vite-tsconfig-paths": "^6.0.2",
    "tailwindcss": "^4.2.1"
  }
}
