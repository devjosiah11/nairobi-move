{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "paths": {
      "@nairobi-move/db": ["../../../shared/db/client.ts"],
      "@nairobi-move/types": ["../../../shared/types/index.ts"],
      "@nairobi-move/utils": ["../../../shared/utils/at.ts"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
