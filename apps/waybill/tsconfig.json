{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "paths": {
      "@nairobi-move/db": ["../../shared/db/client.ts"],
      "@nairobi-move/utils": ["../../shared/utils/index.ts"]
    }
  },
  "include": ["./server/**/*.ts"],
  "exclude": ["node_modules"]
}
