# Waybill app — local development
PORT=3005

# Local Postgres (run via docker-compose up -d)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nairobi_move

# Mock all Africa's Talking sends (SMS / Voice / Airtime).
# Set to "false" to use real AT credentials below.
MOCK_AT=true

# AT credentials (only used when MOCK_AT=false)
AT_API_KEY=
AT_USERNAME=sandbox
AT_SHORTCODE=21606
AT_USSD_CODE=*384*1#
